# gcp-hcp-gitops-promoter-demo configuration
# Copy this file to config.local.env and edit values before running setup.sh

# GitHub App credentials (required)
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY_FILE=  # path to .pem file

# gitops-promoter image — uses a custom build that includes the activePath feature (PR #1337)
PROMOTER_IMAGE=quay.io/patmarti/gitops-promoter
PROMOTER_TAG=gitops-promoter-activepath

# Install from a release manifest URL, or leave empty to use PROMOTER_IMAGE/TAG.
# Leave empty to use the custom image above (loaded into minikube by setup.sh):
PROMOTER_INSTALL_URL=

# Minikube profile name
MINIKUBE_PROFILE=promoter-demo

# ngrok static domain for webhook tunneling (set in config.local.env)
NGROK_DOMAIN=
